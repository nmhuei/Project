from Crypto.Util.number import *

n = 
c = 
p = 
q = 
g = 3

print("[*] Solving DLP mod p...")
Fp = GF(p)
gp = Fp(g)
cp = Fp(c)
xp = discrete_log(cp, gp, ord=gp.multiplicative_order())  # Pohlig-Hellman

# Step 3: discrete log mod q
print("[*] Solving DLP mod q...")
Fq = GF(q)
gq = Fq(g)
cq = Fq(c)
xq = discrete_log(cq, gq, ord=gq.multiplicative_order())  # Pohlig-Hellman

# Step 4: CRT để ghép nghiệm
from sage.all import crt
FLAG_int = crt([xp, xq], [p-1, q-1])  # nghiệm theo modulo lcm(p-1, q-1)

# Step 5: Convert sang bytes
flag = long_to_bytes(int(FLAG_int))
print("[+] FLAG:", flag)